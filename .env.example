# Gneva Environment Variables

# Auth
SECRET_KEY=your-secret-key-here

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-...

# Recall.ai (Meeting bot)
RECALL_API_KEY=your-recall-api-key
RECALL_WEBHOOK_URL=https://your-domain.com

# ElevenLabs (Stage 4+, optional)
ELEVENLABS_API_KEY=

# Database (auto-set in docker-compose)
DATABASE_URL=postgresql+asyncpg://gneva:gneva@localhost:5432/gneva
REDIS_URL=redis://localhost:6379/0

# Azure Communication Services (ACS) — for Teams meeting bot via Call Automation
# When set, the bot uses ACS instead of browser-based Playwright
ACS_CONNECTION_STRING=
ACS_CALLBACK_URL=  # Public URL, e.g., https://your-ngrok.ngrok.io/api/acs/events
ACS_WS_URL=  # Public WSS URL, e.g., wss://your-ngrok.ngrok.io/api/acs/audio

# Storage (optional, defaults to local)
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=
